{
  "name": "example-json-config",
  "description": "Example JSON configuration file for the batch runner",

  "global": {
    "authStrategies": ["none", "service-integrated"],
    "experiment": "webservice",
    "workload": "workload-constant.yml",
    "destroyAfterBenchmark": true,
    "continueOnFailure": true,
    "maxRetries": 1,
    "delayBetweenBenchmarks": 15000,
    "outputBaseDir": "results/example-batch"
  },

  "architectures": {
    "faas": {
      "enabled": true,
      "memoryConfigs": [256, 512, 1024],
      "bundleSizes": ["full"]
    },

    "microservices": {
      "enabled": true,
      "hardwareConfigs": [
        { "cpu": 256, "memory": 512 },
        { "cpu": 512, "memory": 1024 }
      ]
    },

    "monolith": {
      "enabled": true,
      "hardwareConfigs": [
        { "cpu": 256, "memory": 512 },
        { "cpu": 512, "memory": 1024 }
      ]
    }
  }
}